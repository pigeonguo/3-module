def tail_stats_per_seed(curves, K):
    """
    curves: ndarray, shape = (num_seeds, episodes)
    K: last K episodes
    """
    num_seeds = curves.shape[0]

    per_seed_mean = []
    per_seed_var = []
    per_seed_std = []

    for s in range(num_seeds):
        tail = curves[s, -K:]
        per_seed_mean.append(np.mean(tail))
        per_seed_var.append(np.var(tail))   # episode-level variance
        per_seed_std.append(np.std(tail))   # episode-level std

    per_seed_mean = np.array(per_seed_mean)
    per_seed_var  = np.array(per_seed_var)
    per_seed_std  = np.array(per_seed_std)

    return {
        "per_seed_mean": per_seed_mean,
        "per_seed_var":  per_seed_var,
        "per_seed_std":  per_seed_std,
        "mean_of_means": float(np.mean(per_seed_mean)),
        "mean_of_vars":  float(np.mean(per_seed_var)),
        "mean_of_stds":  float(np.mean(per_seed_std)),
        "sum_of_vars":   float(np.sum(per_seed_var)),
        "sum_of_stds":   float(np.sum(per_seed_std)),
    }


def print_tail_stats(title, curves, K, seeds):
    """
    打印 + 返回 stats，方便你在外部继续用 stats 做额外分析
    """
    stats = tail_stats_per_seed(curves, K)

    print("\n" + "=" * 60)
    print(f"{title} (Last {K} Episodes)")
    print("=" * 60)

    for i, (m, v, s) in enumerate(
        zip(stats["per_seed_mean"],
            stats["per_seed_var"],
            stats["per_seed_std"])
    ):
        print(
            f"Seed {seeds[i]} | "
            f"Mean = {m:.4f} | "
            f"Var = {v:.6f} | "
            f"Std = {s:.4f}"
        )

    print("-" * 60)
    print(f"[Across Seeds] Mean of Mean = {stats['mean_of_means']:.4f}")
    print(f"[Across Seeds] Mean of Var  = {stats['mean_of_vars']:.6f}")
    print(f"[Across Seeds] Mean of Std  = {stats['mean_of_stds']:.4f}")
    print(f"[Across Seeds] Sum  of Var  = {stats['sum_of_vars']:.6f}")
    print(f"[Across Seeds] Sum  of Std  = {stats['sum_of_stds']:.4f}")

    return stats

