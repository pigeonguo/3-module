# ==============
# Contextual MAB: Multi-Play LinUCB (for RB selection)
# ==============
class MultiPlayLinUCB:
    def __init__(self, num_arms, dim, alpha=1.0, K=4):
        self.num_arms = num_arms  # RB 数 = 8
        self.alpha = alpha
        self.K = K                # 每次选几个RB = 4
        self.A = [np.identity(dim) for _ in range(num_arms)]
        self.b = [np.zeros((dim, 1)) for _ in range(num_arms)]

    def update(self, arms, X_list, reward):
        r = float(reward)
        for arm in arms:
            x = X_list[arm].reshape(-1, 1)
            self.A[arm] += x @ x.T
            self.b[arm] += r * x

    def choose_arms(self, X_list):
        score_rows = []
        for arm in range(self.num_arms):
            x = X_list[arm].reshape(-1, 1)
            A_inv = np.linalg.inv(self.A[arm])
            theta = A_inv @ self.b[arm]
            mean = (theta.T @ x).item()
            bonus = self.alpha * np.sqrt((x.T @ A_inv @ x).item())
            ucb = mean + bonus
            score_rows.append((ucb, arm))

        score_rows.sort(key=lambda t: t[0], reverse=True)
        arms = [arm for (_, arm) in score_rows[:self.K]]
        return arms

