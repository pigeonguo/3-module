# CMAB-power（RB 版）
# ======================
class BeamMACOLPowerAgent:
    def __init__(self, parent_id, beam_idx, power_levels, is_rsu=True):
        self.parent_id = parent_id
        self.beam_idx = beam_idx
        self.power_levels = power_levels
        self.is_rsu = is_rsu

        self.eps = 1.0
        self.eps_min = 0.01
        self.eps_decay = 0.9997  # 可和 DQN 相同

        self.q_value = {}
        self.q_count = {}
        self.last_keys = []
        self.prev_choice = None

    def _q_get(self, key):
        return self.q_value.get(key, 0.0)

    def _q_update(self, key, reward, alpha=0.1):
        v = self.q_value.get(key, 0.0)
        self.q_value[key] = (1 - alpha) * v + alpha * float(reward)
        self.q_count[key] = self.q_count.get(key, 0) + 1

    def build_context(self, env, context_actions, veh_id):
        """
        Beam/RB 版上下文（升级为 beam-level overlap 判定）：
        - me_rb：上一拍我这条链路用的 RB
        - interferer_cnt：满足【几何可干扰 + beam overlap + 同 RB 发射】的邻居数量
        - max_nb_pidx：这些邻居在 me_rb 上的上一拍最大功率档位（per-RB view）
        """
        me_rb = -1
        if 0 <= self.parent_id < num_agents and 0 <= veh_id < num_vehicle:
            me_rb = int(env.rb_allocation[self.parent_id, int(veh_id)])

        interferer_cnt = 0
        max_nb_pidx = 0

        # 我这条 RSU-link 属于哪个 beam（0..2）
        # 你这里 self.beam_idx 实际是 link_k(0..5)
        my_beam_idx = None
        if self.is_rsu:
            my_beam_idx = int(self.beam_idx) // int(env.max_vehicle_per_beam)  # 0,1,2

        for other in range(num_agents):
            # 同一个 parent（同 RSU / 同 UAV）不互扰
            if other == self.parent_id:
                continue

            # ==========
            # (1) 几何可干扰判定 + beam overlap（仅 RSU-RSU 用）
            # ==========
            could = False

            if other < num_RSU:
                # other 是 RSU：必须满足
                #   - 存在某个 other_beam，使得：
                #       (a) other_beam 覆盖 veh_id
                #       (b) other_beam 与 my_beam overlap
                #       (c) other_beam 在 me_rb 上确实在发射（same-RB-active）
                if (me_rb < 0) or (my_beam_idx is None):
                    # 如果我这条链路没有 RB 或我不是 RSU-link，就无法做 beam级判断
                    could = False
                else:
                    active = env.rsu_beam_vehicle_map.get(other, {})
                    for ob, veh_list in active.items():
                        ob = int(ob)

                        # (a) beam overlap（几何版：你已有 _beams_overlap_idx(rsu_a,beam_a,rsu_b,beam_b)）
                        if not env._beams_overlap_idx(self.parent_id, my_beam_idx, other, ob, allow_adjacent=False):
                            continue

                        # (b) other 的该 beam 必须覆盖到我的 veh_id
                        if not env._vehicle_in_rsu_beam(other, ob, int(veh_id)):
                            continue

                        # (c) other 的该 beam 必须真的在 me_rb 上发射（同RB才算 co-RB interferer）
                        if not env._rsu_beam_uses_rb(other, ob, int(me_rb)):
                            continue

                        could = True
                        break

            else:
                # other 是 UAV：仍用 coverage 判定 + same-RB 判定（UAV无beam扇区）
                other_uav_local = other - num_RSU
                if env._vehicle_in_uav_coverage(other_uav_local, int(veh_id)):
                    # UAV 必须在 me_rb 上对某个 served vehicle 发射，才算同RB干扰
                    if me_rb >= 0:
                        other_served = np.where(env.associations[other] > 0)[0]
                        for sv in other_served:
                            rb_other = int(env.rb_allocation[other, int(sv)])
                            if rb_other == int(me_rb):
                                could = True
                                break

            if not could:
                continue

            # ==========
            # (2) 计数 + 取同RB最大功率档位（per-RB view）
            # ==========
            interferer_cnt += 1

            # context_actions[other]['power'] 是你做的 per-RB view（长度 num_rb）
            if ('power' in context_actions[other]) and context_actions[other]['power']:
                if 0 <= me_rb < num_rb:
                    pidx_same_rb = int(context_actions[other]['power'][int(me_rb)])
                    max_nb_pidx = max(max_nb_pidx, pidx_same_rb)

        # ==========
        # (3) 离散 token
        # ==========
        N_token = f"N{min(interferer_cnt, 3)}"
        M_token = f"M{min(max_nb_pidx, 4)}"

        # RB token（0-7 分组：0-1,2-3,4-5,6-7）
        if me_rb < 0:
            R_token = "RX"
        else:
            if me_rb <= 1:
                R_token = "R0"
            elif me_rb <= 3:
                R_token = "R1"
            elif me_rb <= 5:
                R_token = "R2"
            else:
                R_token = "R3"

        return f"[{R_token},{N_token},{M_token}]"

    def select_power(self, sim_step, env, context_actions, veh_id):
        self.last_keys = []

        # ===== epsilon-greedy: exponential decay  =====
        eps = self.eps

        ctx = self.build_context(env, context_actions, veh_id)
        K = len(self.power_levels)

        if random.random() < eps:
            a = random.randint(0, K - 1)
        else:
            best_val, best_set = -1e9, []
            for pi in range(K):
                q = self._q_get((ctx, pi))
                if q > best_val + 1e-12:
                    best_val, best_set = q, [pi]
                elif abs(q - best_val) <= 1e-12:
                    best_set.append(pi)
            a = random.choice(best_set) if best_set else random.randint(0, K - 1)

        self.prev_choice = a
        self.last_keys.append((ctx, a))
        return a

    def learn_from_reward(self, reward):
        if not self.last_keys:
            return
        r = float(reward)
        for key in self.last_keys:
            self._q_update(key, r, alpha=0.1)
        self.last_keys = []

# ===========================
# Dueling Double DQN Agent
# ===========================
class DQNAgent:
    def __init__(self, state_dim, action_dim, agent_id):
        self.agent_id = agent_id
        self.state_dim = state_dim
        self.action_dim = action_dim
        self.tau = 0.01
        LR = 1e-3; GAMMA = 0.99; BUFFER_SIZE = 20000; BATCH_SIZE = 64

        class DuelingNetwork(nn.Module):
            def __init__(self, s_dim, a_dim):
                super().__init__()
                self.feature = nn.Sequential(nn.Linear(s_dim, 64), nn.ReLU())
                self.value_stream = nn.Sequential(nn.Linear(64, 32), nn.ReLU(), nn.Linear(32, 1))
                self.adv_stream   = nn.Sequential(nn.Linear(64, 32), nn.ReLU(), nn.Linear(32, a_dim))
            def forward(self, x):
                x = self.feature(x)
                v = self.value_stream(x)
                a = self.adv_stream(x)
                return v + a - a.mean(dim=1, keepdim=True)

        self.q = DuelingNetwork(state_dim, action_dim).to(device)
        self.t = DuelingNetwork(state_dim, action_dim).to(device)
        self.t.load_state_dict(self.q.state_dict())
        self.opt = optim.Adam(self.q.parameters(), lr=LR)

        self.mem = deque(maxlen=BUFFER_SIZE)
        self.gamma = GAMMA
        self.batch = BATCH_SIZE
        self.eps, self.eps_min, self.eps_decay = 1.0, 0.01, 0.9997

    def act(self, state, training=True):
        if training and (np.random.rand() < self.eps):
            return np.random.randint(self.action_dim)
        s = torch.FloatTensor(state).unsqueeze(0).to(device)
        with torch.no_grad():
            q = self.q(s)
        return int(torch.argmax(q).item())

    def remember(self, s, a, r, s2, done):
        self.mem.append((s, a, r, s2, done))

    def replay(self):
        if len(self.mem) < self.batch: return
        import random
        batch = random.sample(self.mem, self.batch)
        s, a, r, s2, d = zip(*batch)

        s_arr = np.asarray(s, dtype=np.float32)
        s2_arr = np.asarray(s2, dtype=np.float32)
        a_arr = np.asarray(a, dtype=np.int64)
        r_arr = np.asarray(r, dtype=np.float32)
        d_arr = np.asarray(d, dtype=np.float32)

        s = torch.from_numpy(s_arr).to(device)
        s2 = torch.from_numpy(s2_arr).to(device)
        a = torch.from_numpy(a_arr).unsqueeze(1).to(device)
        r = torch.from_numpy(r_arr).unsqueeze(1).to(device)
        d = torch.from_numpy(d_arr).unsqueeze(1).to(device)

        q_sa = self.q(s).gather(1, a) #当前Q（s，a）

        #计算TD target
        with torch.no_grad():
            a2 = self.q(s2).argmax(1, keepdim=True)
            q_s2a2 = self.t(s2).gather(1, a2)
            target = r + (1 - d) * self.gamma * q_s2a2

        loss = nn.SmoothL1Loss()(q_sa, target)
        self.opt.zero_grad(); loss.backward(); self.opt.step()

        # soft update
        for tp, p in zip(self.t.parameters(), self.q.parameters()):
            tp.data.copy_(self.tau * p.data + (1 - self.tau) * tp.data)

