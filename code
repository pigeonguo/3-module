import numpy as np

def moving_average(x, W=10):
    x = np.asarray(x, dtype=np.float64)
    if W <= 1:
        return x
    if len(x) < W:
        # 长度不足时，直接返回整体均值的常数序列（避免报错）
        return np.full_like(x, fill_value=float(np.mean(x)) if len(x) > 0 else 0.0, dtype=np.float64)
    kernel = np.ones(W, dtype=np.float64) / W
    # 'valid' 会变短；为了保持长度，我们在前面 pad
    y_valid = np.convolve(x, kernel, mode="valid")
    pad = np.full(W - 1, y_valid[0], dtype=np.float64)
    return np.concatenate([pad, y_valid])

def time_to_threshold(curve, K_tail=100, ratio=0.90, W=10, M=10):
    """
    e_90: 最早达到 ratio * tail_mean 的 episode index（0-based），并要求连续 M 个点都满足。
    如果找不到，返回 np.nan
    """
    curve = np.asarray(curve, dtype=np.float64)
    T = len(curve)
    if T == 0:
        return np.nan

    K_tail = int(min(max(1, K_tail), T))
    tail_mean = float(np.mean(curve[-K_tail:]))
    thr = ratio * tail_mean

    sm = moving_average(curve, W=W)

    # 连续 M 个 episode 都 >= thr 才算“真正进入”
    for e in range(0, T - M + 1):
        if np.all(sm[e:e+M] >= thr):
            return float(e)  # episode index (0-based)
    return np.nan

def auc_first_N(curve, N=200, W=10):
    """
    AUC_N: 前 N 个 episode 的平滑曲线求和
    """
    curve = np.asarray(curve, dtype=np.float64)
    if len(curve) == 0:
        return 0.0
    N = int(min(max(1, N), len(curve)))
    sm = moving_average(curve, W=W)
    return float(np.sum(sm[:N]))

def speed_stats_per_seed(curves, seeds, K_tail=100, ratio=0.90, W=10, M=10, auc_list=(200, 300), title=""):
    """
    curves: (num_seeds, episodes)
    打印 per-seed + across-seed 的 e_90 和 AUC
    """
    curves = np.asarray(curves, dtype=np.float64)
    num_seeds = curves.shape[0]

    e90s = []
    aucs = {N: [] for N in auc_list}

    for s in range(num_seeds):
        e90 = time_to_threshold(curves[s], K_tail=K_tail, ratio=ratio, W=W, M=M)
        e90s.append(e90)
        for N in auc_list:
            aucs[N].append(auc_first_N(curves[s], N=N, W=W))

    e90s = np.asarray(e90s, dtype=np.float64)
    for N in auc_list:
        aucs[N] = np.asarray(aucs[N], dtype=np.float64)

    print("\n" + "=" * 60)
    print(f"{title} | Convergence-Speed Metrics")
    print("=" * 60)
    print(f"Definition: e_90 = earliest episode where MA(W={W}) >= 0.90 * mean(last K_tail={K_tail}), sustained M={M}")

    for i in range(num_seeds):
        # e_90 用 1-based episode 更符合直觉（可选）
        e90_show = "NA" if np.isnan(e90s[i]) else f"{int(e90s[i]) + 1:d}"
        msg = f"Seed {seeds[i]} | e_90(ep) = {e90_show}"
        for N in auc_list:
            msg += f" | AUC_{N} = {aucs[N][i]:.4f}"
        print(msg)

    # across-seeds：对 e_90，忽略 NA
    valid_e90 = e90s[~np.isnan(e90s)]
    if valid_e90.size > 0:
        print("-" * 60)
        print(f"[Across Seeds] e_90 mean = {np.mean(valid_e90) + 1:.2f} ep | std = {np.std(valid_e90):.2f}")
    else:
        print("-" * 60)
        print("[Across Seeds] e_90 mean/std = NA (no seed reached threshold under this criterion)")

    for N in auc_list:
        print(f"[Across Seeds] AUC_{N} mean = {np.mean(aucs[N]):.4f} | std = {np.std(aucs[N]):.4f}")

    return {"e90": e90s, "auc": aucs}


